# Copy to ".env" and fill in real values. Do not commit secrets.
# Loaded automatically by pydantic-settings for src/settings.py when .env exists.
# For `python src/main.py`, prepare_request() also requires the variables below.

# -----------------------------------------------------------------------------
# Test run (required for src/main.py via prepare_request)
# -----------------------------------------------------------------------------
# ISO 8601 datetime (timezone-aware recommended; Moscow offset is handled in the model)
START_TEST=2025-04-14T15:03:41+00:00
UUID_TEST=00000000-0000-0000-0000-000000000001
# JSON array: each step [ramp_up_min, duration_min, ramp_down_min, load_percent_or_rps]
LOAD_PLAN=[[0,5,0,25],[0,5,0,50],[0,5,0,75]]
JMX_PATH=/path/to/test.jmx
TEST_DESC=Example load test
TESTNAME=smoke-run
TEST_TYPE=max_performance_search

UI_VERSION=1.0.0
CMS_VERSION=1.0.0
DB_VERSION=main
APP_VERSIONS={}

# -----------------------------------------------------------------------------
# Confluence (required by prepare_request; adjust for your wiki)
# -----------------------------------------------------------------------------
CONFLUENCE_HOST=confluence.example.com
CONFLUENCE_SPACE=PERF
CONFLUENCE_TOKEN=your-api-token-or-pat
CONFLUENCE_PAGE=
CONFLUENCE_TITLE=Load test report
CONFLUENCE_PARENT=
PARENT_PAGE=12345678

# -----------------------------------------------------------------------------
# InfluxDB 2.x (Flux) — required by prepare_request
# -----------------------------------------------------------------------------
INFLUX_URL=http://127.0.0.1:8086
INFLUX_HOST=127.0.0.1
INFLUX_PORT=8086
INFLUX_ORG=org
INFLUX_BUCKET=jmeter
INFLUX_DB=jmeter
INFLUX_TOKEN=your-influx-token

# -----------------------------------------------------------------------------
# Grafana snapshots — full dashboard URLs; { } placeholder is filled with run UUID for JMeter template
# -----------------------------------------------------------------------------
GRAFANA_HOST=grafana.example.com
GRAFANA_USER=admin
GRAFANA_PASS=changeme
GRAFANA_SNAPSHOT_JMETER=https://grafana.example.com/d/uid/report-jmeter-flux?var-runId={}
GRAFANA_SNAPSHOT_NODEJS=https://grafana.example.com/d/uid/report-pods?var-workload=app
GRAFANA_SNAPSHOT_ELASTIC=https://grafana.example.com/d/uid/report-request-time-analyze
GRAFANA_SNAPSHOT_PODS=https://grafana.example.com/d/uid/report-pods-metrics
GRAFANA_SNAPSHOT_NODES=https://grafana.example.com/d/uid/report-node-exporter-full

# -----------------------------------------------------------------------------
# Argo CD + Vault (required keys; use dummy values if sections are unused)
# -----------------------------------------------------------------------------
ARGO_URL=https://argocd.example.com
ARGO_TOKEN=your-argocd-token
VAULT_TOKEN=your-vault-token

# -----------------------------------------------------------------------------
# Chat bot (Express-compatible JWT API) — required by prepare_request
# -----------------------------------------------------------------------------
CTS_HOST=notifications.example.com
BOT_ID=00000000-0000-0000-0000-000000000000
SECRET_KEY=your-hs256-signing-secret
CHAT_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# Misc (required by prepare_request)
# -----------------------------------------------------------------------------
REPORT_URL=https://confluence.example.com/display/PERF/Reports
SERVICE=my-service

# -----------------------------------------------------------------------------
# Optional — report pipeline toggles (defaults: True / True / empty)
# -----------------------------------------------------------------------------
CREATE_REPORT=True
SAVE_TO_STORAGE=False
SEND_BOT_NOTIFICATION=False
CLINIC_REPORTS_URL=
TAURUS_EXIT_CODE=0

# -----------------------------------------------------------------------------
# Optional — Argo adapter / OIDC (src/clients/argocd.py)
# -----------------------------------------------------------------------------
KEYCLOAK_AUTH_URL=https://sso.example.com/auth/realms/example/login-actions/authenticate
ARGO_OAUTH_CLIENT_ID=argocd

# -----------------------------------------------------------------------------
# Optional — Yandex Wiki OAuth (src/clients/yandex_client.py)
# -----------------------------------------------------------------------------
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=https://localhost

# -----------------------------------------------------------------------------
# Optional — defaults for pydantic Settings (src/settings.py); override any field
# -----------------------------------------------------------------------------
# CONFLUENCE_LOGIN=admin
# CONFLUENCE_PASSWORD=changeme
# GRAFANA_LOGIN=admin
# GRAFANA_PASSWORD=changeme
# ARGO_HOST=argocd.example.com
# ARGO_LOGIN=
# ARGO_PASSWORD=
# INFLUX_USER=
# INFLUX_PWD=
# OPERATION_FILTER=test
